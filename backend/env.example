# Copy this file to ".env" (no .example) and fill in your real values.
# .env is in .gitignore and will NOT be committed — this file (.env.example) is fine to commit.

MONGO_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority

# Optional — defaults to sentinel.db in this folder if unset
SQLITE_PATH=sentinel.db
